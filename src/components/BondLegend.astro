---
import type { BondMeta } from '../lib/data';

type Props = {
  bonds: BondMeta[];
};

const { bonds } = Astro.props;
---

<div class="bond-legend" role="list" aria-label="Bond legend">
  {bonds.map((bond) => (
    <article class="bond-legend-item" role="listitem">
      <svg width="40" height="18" viewBox="0 0 40 18" aria-hidden="true">
        <defs>
          <marker id={`bond-arrow-${bond.type}`} viewBox="0 0 10 10" refX="8" refY="5" markerWidth="6" markerHeight="6" orient="auto">
            <path d="M2 1L8 5L2 9" fill="none" stroke={bond.accent_color} stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
          </marker>
        </defs>

        {bond.stroke_style === 'solid' && (
          <line x1="3" y1="9" x2="37" y2="9" stroke={bond.accent_color} stroke-width="2" />
        )}

        {bond.stroke_style === 'double' && (
          <>
            <line x1="3" y1="6" x2="37" y2="6" stroke={bond.accent_color} stroke-width="2.25" />
            <line x1="3" y1="12" x2="37" y2="12" stroke={bond.accent_color} stroke-width="1.1" opacity="0.65" />
          </>
        )}

        {bond.stroke_style === 'dashed' && (
          <line x1="3" y1="9" x2="37" y2="9" stroke={bond.accent_color} stroke-width="1.8" stroke-dasharray="5,3" />
        )}

        {bond.stroke_style === 'protocol' && (
          <line x1="3" y1="9" x2="37" y2="9" stroke={bond.accent_color} stroke-width="1.6" stroke-dasharray="3,3" />
        )}

        {bond.stroke_style === 'absent' && (
          <>
            <line x1="3" y1="9" x2="37" y2="9" stroke={bond.accent_color} stroke-width="1.4" stroke-dasharray="3,5" />
            <circle cx="20" cy="9" r="6.25" fill="none" stroke={bond.accent_color} stroke-width="1" opacity="0.55" />
          </>
        )}

        {bond.stroke_style === 'loop' && (
          <path
            d="M 8 12 Q 20 1 32 12"
            fill="none"
            stroke={bond.accent_color}
            stroke-width="1.8"
            stroke-dasharray="6,3"
            marker-end={`url(#bond-arrow-${bond.type})`}
          />
        )}
      </svg>

      <div>
        <p class="bond-legend-label">{bond.label}</p>
        <p class="bond-legend-copy">{bond.notation} · {bond.meaning}</p>
      </div>
    </article>
  ))}
</div>
