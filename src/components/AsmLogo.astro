---
type Props = {
  compact?: boolean;
};

const { compact = false } = Astro.props;
---

<span class={`asm-brand ${compact ? 'compact' : ''}`}>
  <svg class="asm-brand-mark" viewBox="0 0 44 44" aria-hidden="true" focusable="false">
    <defs>
      <linearGradient id="asmBrandGradient" x1="0%" y1="0%" x2="100%" y2="100%">
        <stop offset="0%" stop-color="#67B7FF"></stop>
        <stop offset="55%" stop-color="#8C80FF"></stop>
        <stop offset="100%" stop-color="#3EE0B7"></stop>
      </linearGradient>
    </defs>
    <path
      d="M22 5.5 35.8 13.5 35.8 29.5 22 37.5 8.2 29.5 8.2 13.5Z"
      fill="none"
      stroke="url(#asmBrandGradient)"
      stroke-width="1.8"
    />
    <path
      d="M15.2 26.6 21.9 12.7 28.8 26.6M17.7 21.8H26.3"
      fill="none"
      stroke="currentColor"
      stroke-width="1.9"
      stroke-linecap="round"
      stroke-linejoin="round"
    />
    <circle cx="22" cy="8.8" r="2.1" fill="#67B7FF" />
    <circle cx="33.8" cy="30.2" r="2.1" fill="#8C80FF" />
    <circle cx="10.2" cy="30.2" r="2.1" fill="#3EE0B7" />
  </svg>

  <span class="asm-brand-copy">
    <span class="asm-brand-kicker">ASM</span>
    <span class="asm-brand-name">The Agentic Standard Model</span>
  </span>
</span>
