---
type Props = {
  title: string;
};

const { title } = Astro.props;
---

<svg class="molecule-svg" width="480" height="220" viewBox="0 0 480 220" role="img" aria-label={title}>
  <defs>
    <marker id="reflexive-arrow" viewBox="0 0 10 10" refX="8" refY="5" markerWidth="6" markerHeight="6" orient="auto-start-reverse">
      <path d="M2 1L8 5L2 9" fill="none" stroke="#1D9E75" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"></path>
    </marker>
  </defs>

  <line x1="202" y1="98" x2="152" y2="148" stroke="#6a9fd4" stroke-width="2"></line>
  <line x1="238" y1="98" x2="288" y2="148" stroke="#6a9fd4" stroke-width="2"></line>
  <path d="M 168 170 Q 220 210 280 170" fill="none" stroke="#1D9E75" stroke-width="2" stroke-dasharray="6,3" marker-end="url(#reflexive-arrow)"></path>
  <path d="M 280 158 Q 220 120 168 158" fill="none" stroke="#1D9E75" stroke-width="1.2" stroke-dasharray="4,4" opacity="0.5"></path>

  <text x="224" y="204" text-anchor="middle" class="mol-bond-label" fill="#1D9E75">feedback loop</text>

  <circle cx="220" cy="72" r="28" fill="#2e1308" stroke="#D85A30" stroke-width="1.5"></circle>
  <text x="220" y="68" text-anchor="middle" class="mol-sym" fill="#F0997B">Lm</text>
  <text x="220" y="90" text-anchor="middle" class="mol-lbl">LLM</text>

  <circle cx="136" cy="166" r="28" fill="#0a2219" stroke="#1D9E75" stroke-width="1"></circle>
  <text x="136" y="162" text-anchor="middle" class="mol-sym" fill="#5DCAA5">Em</text>
  <text x="136" y="182" text-anchor="middle" class="mol-lbl">Episodic Mem.</text>

  <circle cx="308" cy="166" r="28" fill="#131e07" stroke="#639922" stroke-width="1"></circle>
  <text x="308" y="162" text-anchor="middle" class="mol-sym" fill="#97C459">Ds</text>
  <text x="308" y="182" text-anchor="middle" class="mol-lbl">Decision Skill</text>
</svg>
