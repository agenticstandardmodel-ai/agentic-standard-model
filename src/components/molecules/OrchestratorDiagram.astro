---
type Props = {
  title: string;
};

const { title } = Astro.props;
---

<svg class="molecule-svg" width="680" height="220" viewBox="0 0 680 220" role="img" aria-label={title}>
  <line x1="86" y1="80" x2="152" y2="80" stroke="#6a9fd4" stroke-width="2"></line>
  <line x1="208" y1="77" x2="290" y2="77" stroke="#d4b26a" stroke-width="2.5"></line>
  <line x1="208" y1="84" x2="290" y2="84" stroke="#d4b26a" stroke-width="1" opacity="0.5"></line>
  <line x1="180" y1="52" x2="180" y2="28" stroke="#EF9F27" stroke-width="1.5" stroke-dasharray="3,3"></line>
  <line x1="300" y1="52" x2="300" y2="28" stroke="#EF9F27" stroke-width="1.8" stroke-dasharray="3,3"></line>
  <line x1="420" y1="52" x2="420" y2="28" stroke="#EF9F27" stroke-width="1.5" stroke-dasharray="3,3"></line>

  <line x1="318" y1="108" x2="120" y2="148" stroke="#9fd46a" stroke-width="1.5" stroke-dasharray="5,3"></line>
  <line x1="318" y1="108" x2="210" y2="148" stroke="#9fd46a" stroke-width="1.5" stroke-dasharray="5,3"></line>
  <line x1="318" y1="108" x2="310" y2="148" stroke="#9fd46a" stroke-width="1.5" stroke-dasharray="5,3"></line>

  <circle cx="62" cy="80" r="24" fill="#131e07" stroke="#639922" stroke-width="1"></circle>
  <text x="62" y="76" text-anchor="middle" class="mol-sym-sm" fill="#97C459">Ds</text>
  <text x="62" y="92" text-anchor="middle" class="mol-lbl">Decision</text>

  <circle cx="180" cy="80" r="28" fill="#2e1308" stroke="#D85A30" stroke-width="1.5"></circle>
  <text x="180" y="76" text-anchor="middle" class="mol-sym" fill="#F0997B">Lm</text>
  <text x="180" y="98" text-anchor="middle" class="mol-lbl">LLM</text>

  <circle cx="318" cy="80" r="28" fill="#1a1535" stroke="#d4b26a" stroke-width="2"></circle>
  <text x="318" y="72" text-anchor="middle" class="mol-sym" fill="#d4b26a">Ws</text>
  <text x="318" y="87" text-anchor="middle" class="mol-mono-sm" fill="#d4b26a">=</text>

  <rect x="88" y="148" width="64" height="38" rx="6" fill="#0e1014" stroke="#2d2560" stroke-width="1" stroke-dasharray="4,2"></rect>
  <text x="120" y="162" text-anchor="middle" class="mol-mono" fill="#7F77DD">Ag1</text>
  <text x="120" y="177" text-anchor="middle" class="mol-lbl">sub-agent</text>

  <rect x="178" y="148" width="64" height="38" rx="6" fill="#0e1014" stroke="#2d2560" stroke-width="1" stroke-dasharray="4,2"></rect>
  <text x="210" y="162" text-anchor="middle" class="mol-mono" fill="#7F77DD">Ag2</text>
  <text x="210" y="177" text-anchor="middle" class="mol-lbl">sub-agent</text>

  <rect x="278" y="148" width="64" height="38" rx="6" fill="#0e1014" stroke="#2d2560" stroke-width="1" stroke-dasharray="4,2"></rect>
  <text x="310" y="162" text-anchor="middle" class="mol-mono" fill="#7F77DD">Agn</text>
  <text x="310" y="177" text-anchor="middle" class="mol-lbl">sub-agent</text>

  <text x="195" y="210" text-anchor="middle" class="mol-bond-label" fill="#9fd46a">ionic· configurable set</text>

  <rect x="145" y="4" width="70" height="22" rx="4" fill="#261c00" stroke="#EF9F27" stroke-width="0.75"></rect>
  <text x="180" y="19" text-anchor="middle" class="mol-mono" fill="#EF9F27">[Mc]</text>

  <rect x="265" y="4" width="70" height="22" rx="4" fill="#261c00" stroke="#EF9F27" stroke-width="1"></rect>
  <text x="300" y="19" text-anchor="middle" class="mol-mono" fill="#EF9F27">[A2]</text>

  <rect x="385" y="4" width="70" height="22" rx="4" fill="#261c00" stroke="#EF9F27" stroke-width="0.75"></rect>
  <text x="420" y="19" text-anchor="middle" class="mol-mono" fill="#EF9F27">[A3]</text>

  <text x="300" y="46" text-anchor="middle" class="mol-lbl" fill="#EF9F27">structurally required</text>
  <text x="254" y="69" text-anchor="middle" class="mol-bond-label" fill="#d4b26a">double bond</text>
