---
type Props = {
  title: string;
};

const { title } = Astro.props;
---

<svg class="molecule-svg" width="620" height="185" viewBox="0 0 620 185" role="img" aria-label={title}>
  <line x1="208" y1="77" x2="280" y2="77" stroke="#d4b26a" stroke-width="2.5"></line>
  <line x1="208" y1="84" x2="280" y2="84" stroke="#d4b26a" stroke-width="1" opacity="0.5"></line>
  <line x1="340" y1="80" x2="400" y2="80" stroke="#6a9fd4" stroke-width="2"></line>
  <line x1="180" y1="52" x2="180" y2="28" stroke="#6a9fd4" stroke-width="2"></line>
  <line x1="418" y1="108" x2="380" y2="140" stroke="#6a9fd4" stroke-width="2"></line>
  <line x1="432" y1="108" x2="468" y2="140" stroke="#6a9fd4" stroke-width="2"></line>
  <line x1="300" y1="52" x2="300" y2="28" stroke="#EF9F27" stroke-width="1.5" stroke-dasharray="3,3"></line>
  <path d="M175 108 Q175 120 200 120 L340 120 Q365 120 365 108" fill="none" stroke="#d4b26a" stroke-width="0.75" opacity="0.5"></path>
  <text x="270" y="135" text-anchor="middle" class="mol-lbl" fill="#d4b26a">defining structural pair</text>

  <circle cx="180" cy="80" r="28" fill="#2e1308" stroke="#D85A30" stroke-width="1.5"></circle>
  <text x="180" y="76" text-anchor="middle" class="mol-sym" fill="#F0997B">Lm</text>
  <text x="180" y="98" text-anchor="middle" class="mol-lbl">LLM</text>

  <circle cx="310" cy="80" r="28" fill="#1a1535" stroke="#d4b26a" stroke-width="2"></circle>
  <text x="310" y="72" text-anchor="middle" class="mol-sym" fill="#d4b26a">Ws</text>
  <text x="310" y="87" text-anchor="middle" class="mol-mono-sm" fill="#d4b26a">=</text>

  <circle cx="428" cy="80" r="26" fill="#1a1535" stroke="#7F77DD" stroke-width="1"></circle>
  <text x="428" y="76" text-anchor="middle" class="mol-sym-sm" fill="#AFA9EC">Cp</text>
  <text x="428" y="92" text-anchor="middle" class="mol-lbl">Checkpoint</text>

  <circle cx="180" cy="18" r="18" fill="#1a1535" stroke="#7F77DD" stroke-width="1"></circle>
  <text x="180" y="22" text-anchor="middle" class="mol-mono" fill="#AFA9EC">Es</text>

  <circle cx="360" cy="158" r="22" fill="#280e1c" stroke="#D4537E" stroke-width="1"></circle>
  <text x="360" y="163" text-anchor="middle" class="mol-sym-sm" fill="#ED93B1">Rt</text>

  <circle cx="490" cy="158" r="22" fill="#280e1c" stroke="#D4537E" stroke-width="1"></circle>
  <text x="490" y="163" text-anchor="middle" class="mol-sym-sm" fill="#ED93B1">Wt</text>

  <rect x="265" y="4" width="70" height="22" rx="4" fill="#261c00" stroke="#EF9F27" stroke-width="0.75"></rect>
  <text x="300" y="19" text-anchor="middle" class="mol-mono" fill="#EF9F27">[Mc]</text>

  <text x="244" y="68" text-anchor="middle" class="mol-bond-label" fill="#d4b26a">double bond</text>
</svg>
