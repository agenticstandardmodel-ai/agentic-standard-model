---
type Props = {
  title: string;
};

const { title } = Astro.props;
---

<svg class="molecule-svg" width="580" height="165" viewBox="0 0 580 165" role="img" aria-label={title}>
  <line x1="108" y1="80" x2="170" y2="80" stroke="#6a9fd4" stroke-width="2"></line>
  <line x1="230" y1="80" x2="295" y2="80" stroke="#6a9fd4" stroke-width="2"></line>
  <line x1="200" y1="52" x2="200" y2="28" stroke="#6a9fd4" stroke-width="2"></line>

  <line x1="200" y1="108" x2="160" y2="142" stroke="#333" stroke-width="1" stroke-dasharray="3,5" opacity="0.5"></line>
  <line x1="200" y1="108" x2="260" y2="142" stroke="#333" stroke-width="1" stroke-dasharray="3,5" opacity="0.5"></line>

  <circle cx="82" cy="80" r="24" fill="#280e1c" stroke="#D4537E" stroke-width="1"></circle>
  <text x="82" y="76" text-anchor="middle" class="mol-sym-sm" fill="#ED93B1">Rt</text>
  <text x="82" y="92" text-anchor="middle" class="mol-lbl">Read Tool</text>

  <circle cx="200" cy="80" r="28" fill="#2e1308" stroke="#D85A30" stroke-width="1.5"></circle>
  <text x="200" y="76" text-anchor="middle" class="mol-sym" fill="#F0997B">Lm</text>
  <text x="200" y="98" text-anchor="middle" class="mol-lbl">LLM</text>

  <circle cx="322" cy="80" r="25" fill="#0a2219" stroke="#1D9E75" stroke-width="1"></circle>
  <text x="322" y="76" text-anchor="middle" class="mol-sym-sm" fill="#5DCAA5">Ss</text>
  <text x="322" y="92" text-anchor="middle" class="mol-lbl">Session Mem.</text>

  <circle cx="200" cy="18" r="18" fill="#131e07" stroke="#639922" stroke-width="1"></circle>
  <text x="200" y="22" text-anchor="middle" class="mol-mono" fill="#97C459">Is</text>

  <g opacity="0.25">
    <circle cx="148" cy="155" r="20" fill="#111" stroke="#333" stroke-width="1" stroke-dasharray="3,3"></circle>
    <text x="148" y="152" text-anchor="middle" class="mol-mono" fill="#444">Wt</text>
    <text x="148" y="165" text-anchor="middle" class="mol-lbl">Write Tool</text>

    <circle cx="262" cy="155" r="20" fill="#111" stroke="#3d2d00" stroke-width="1" stroke-dasharray="3,3"></circle>
    <text x="262" y="152" text-anchor="middle" class="mol-mono" fill="#4a3d00">A2</text>
    <text x="262" y="165" text-anchor="middle" class="mol-lbl">Delegation</text>
  </g>

  <text x="148" y="136" text-anchor="middle" class="mol-mono-sm" fill="#3a3a3a">∅Wt</text>
  <text x="262" y="136" text-anchor="middle" class="mol-mono-sm" fill="#3a3a3a">∅A2</text>
</svg>
