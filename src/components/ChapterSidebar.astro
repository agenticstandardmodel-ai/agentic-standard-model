---
import { chapterAccents, chapterLabel, statusLabels } from '../lib/chapters';
import { siteNavItems } from '../lib/site-nav';

type ChapterItem = {
  slug: string;
  data: {
    title: string;
    chapter_number: number;
    summary: string;
    status: 'placeholder' | 'draft' | 'published';
  };
};

type Props = {
  chapters: ChapterItem[];
  currentSlug?: string;
};

const { chapters, currentSlug } = Astro.props;
const year = new Date().getFullYear();
---

<aside class="chapter-sidebar" aria-label="Chapters">
  <nav class="chapter-sidebar-site-nav" aria-label="Primary">
    <a href="/">Home</a>
    {siteNavItems
      .filter((item) => item.id !== 'home')
      .map((item) => <a href={item.href}>{item.label}</a>)}
  </nav>

  <div class="chapter-sidebar-header">
    <p class="kicker">ASM v0.3</p>
    <h2>Chapters</h2>
  </div>

  <nav>
    <ol class="chapter-list">
      {chapters.map((chapter) => {
        const active = chapter.slug === currentSlug;
        const chapterNum = chapter.data.chapter_number;
        const accent = chapterAccents[chapterNum] || chapterAccents[1];
        const statusLabel = statusLabels[chapter.data.status] || chapter.data.status;

        return (
          <li class={`chapter-item ${active ? 'active' : ''}`} data-chapter-item data-chapter={chapterNum}>
            <a href={`/${chapter.slug}/`} aria-current={active ? 'page' : undefined}>
              <span class="chapter-num" style={`color:${accent}`}>{chapterNum.toString().padStart(2, '0')}</span>
              <span class="chapter-main">
                <span class="chapter-title-row">
                  <strong>{chapterLabel(chapter.data.title, chapterNum)}</strong>
                  <span class={`status-badge ${chapter.data.status}`}>{statusLabel}</span>
                </span>
                <small>{chapter.data.summary}</small>
              </span>
            </a>
            {active && <ol class="chapter-section-list" data-active-section-list></ol>}
          </li>
        );
      })}
    </ol>
  </nav>

  <div class="chapter-sidebar-footer">
    <a href="/table/">Periodic Table</a>
    <p>© {year} ASM</p>
  </div>
</aside>
