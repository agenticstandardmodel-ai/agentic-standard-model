---
import BaseLayout from '../../layouts/BaseLayout.astro';
import FigureEmbed from '../../components/FigureEmbed.astro';
import TopBar from '../../components/TopBar.astro';
import SiteDrawerNav from '../../components/SiteDrawerNav.astro';
import OutlineSidebar from '../../components/OutlineSidebar.astro';
import { getFigures } from '../../lib/data';
import { getCollection } from 'astro:content';
import { chapterAccents, chapterSlugFromNumber } from '../../lib/chapters';

const chapters = (await getCollection('chapters')).sort(
  (a, b) => a.data.chapter_number - b.data.chapter_number
);

export function getStaticPaths() {
  const figures = getFigures();
  return figures.map((figure) => ({
    params: { id: figure.id },
    props: { figure }
  }));
}

const { figure } = Astro.props;
const canonicalPath = `/figures/${figure.id}/`;
const chapterSlug = chapterSlugFromNumber(figure.chapter);
const chapterHref = `/${chapterSlug}/`;
const chapterAccent = chapterAccents[figure.chapter] || chapterAccents[1];
const relatedFigures = getFigures()
  .filter((item) => item.chapter === figure.chapter && item.id !== figure.id)
  .map((item) => ({ id: item.id, label: item.label, title: item.title, href: `/figures/${item.id}/` }));
---

<BaseLayout title={`${figure.title} — ASM Figure`} description={figure.caption} canonicalPath={canonicalPath}>
  <div class="app-shell no-outline" style={`--chapter-accent:${chapterAccent}`}>
    <TopBar chapters={chapters} currentChapterNumber={figure.chapter} currentNav="chapters" />
    <div class="mobile-nav-overlay" data-nav-overlay></div>

    <aside class="sidenav site-drawer" data-sidenav>
      <SiteDrawerNav chapters={chapters} currentNav="chapters" />
    </aside>

    <section class="content-pane">
      <article class="doc-content figure-detail" data-doc-content>
        <p class="chapter-index">Figure Reference</p>
        <h1>{figure.title}</h1>
        <p class="chapter-meta">Chapter {figure.chapter}</p>
        <p><a href={chapterHref}>← Back to Chapter {figure.chapter}</a></p>

        <FigureEmbed figure={figure} />
      </article>
    </section>

    <aside class="outline-pane">
      <OutlineSidebar title="Figure Reference" figureTitle="Related Figures" figures={relatedFigures} />
    </aside>
  </div>
</BaseLayout>
