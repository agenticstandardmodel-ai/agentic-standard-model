---
import BaseLayout from '../layouts/BaseLayout.astro';
import ChapterSidebar from '../components/ChapterSidebar.astro';
import TopBar from '../components/TopBar.astro';
import OutlineSidebar from '../components/OutlineSidebar.astro';
import { getCollection } from 'astro:content';
import { statusLabels } from '../lib/chapters';

const chapters = (await getCollection('chapters')).sort(
  (a, b) => a.data.chapter_number - b.data.chapter_number
);
---

<BaseLayout
  title="Agentic Standard Model — Interactive Textbook"
  description="The Agentic Standard Model is a theory for classifying and composing agentic systems from irreducible elements with explicit dependency and force structure."
  canonicalPath="/"
>
  <div class="app-shell" style="--chapter-accent:#378ADD">
    <TopBar chapters={chapters} />
    <div class="mobile-nav-overlay" data-nav-overlay></div>

    <aside class="sidenav" data-sidenav>
      <ChapterSidebar chapters={chapters} />
    </aside>

    <section class="content-pane">
      <article class="doc-content home-page" data-doc-content>
        <p class="chapter-index">Interactive Textbook</p>
        <h1>Agentic Standard Model</h1>
        <p class="chapter-meta">
          A structural theory for agentic systems: what must exist, how components compose, and which conservation
          constraints govern valid architectures.
        </p>

        <section class="panel">
          <h2>Thesis</h2>
          <p>
            ASM argues that agentic systems are not arbitrary stacks of tools and prompts. They are structured
            compositions of irreducible elements with dependency-derived periods, functional groups, and force-channel
            constraints.
          </p>
        </section>

        <section class="panel">
          <h2>Read Path</h2>
          <p>
            Start with <a href="/chapter-1-foundations/">Chapter 1</a> for problem framing and historical method,
            then move to <a href="/chapter-2-periodic-table/">Chapter 2</a> for the taxonomy and dependency logic.
          </p>
          <p>
            Flagship visual: <a href="/figures/fig-2-1/">Figure 2.1 — ASM Periodic Table</a>.
          </p>
        </section>

        <section class="panel chapter-cards">
          <h2>Table of Contents</h2>
          <div class="cards">
            {chapters.map((chapter) => (
              <article class="card">
                <p class="card-num">Chapter {chapter.data.chapter_number.toString().padStart(2, '0')}</p>
                <h3><a href={`/${chapter.slug}/`}>{chapter.data.title}</a></h3>
                <p>{chapter.data.summary}</p>
                <span class={`status ${chapter.data.status}`}>{statusLabels[chapter.data.status] || chapter.data.status}</span>
              </article>
            ))}
          </div>
        </section>
      </article>
    </section>

    <aside class="outline-pane">
      <OutlineSidebar />
    </aside>
  </div>
</BaseLayout>
