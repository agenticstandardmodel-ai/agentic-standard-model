---
import BaseLayout from '../layouts/BaseLayout.astro';
import ChapterSidebar from '../components/ChapterSidebar.astro';
import FigureEmbed from '../components/FigureEmbed.astro';
import TopBar from '../components/TopBar.astro';
import OutlineSidebar from '../components/OutlineSidebar.astro';
import { getCollection } from 'astro:content';
import { getFigureMap } from '../lib/data';
import { chapterAccents, chapterEyebrow, chapterNavLabel, chapterLabel, statusLabels } from '../lib/chapters';

const chapters = (await getCollection('chapters')).sort(
  (a, b) => a.data.chapter_number - b.data.chapter_number
);
const figureMap = getFigureMap();

export async function getStaticPaths() {
  const chapters = await getCollection('chapters');
  return chapters.map((chapter) => ({
    params: { slug: chapter.slug }
  }));
}

const { slug } = Astro.params;
const chapter = chapters.find((item) => item.slug === slug);

if (!chapter) {
  throw new Error(`Unknown chapter slug: ${slug}`);
}

const { Content } = await chapter.render();
const chapterFigures = chapter.data.figure_ids
  .map((id) => figureMap.get(id))
  .filter((figure) => figure !== undefined);
const figureLinks = chapterFigures.map((figure) => ({
  id: figure.id,
  label: figure.label,
  title: figure.title
}));

const chapterTitle = chapter.data.title;
const chapterDescription = chapter.data.summary;
const canonicalPath = `/${chapter.slug}/`;
const chapterNumber = chapter.data.chapter_number;
const chapterAccent = chapterAccents[chapterNumber] || chapterAccents[1];
const isScaffolded = chapter.data.status === 'placeholder';
const hasInlineFigurePlacement = chapter.slug === 'chapter-1-foundations';
const chapterIndex = chapters.findIndex((item) => item.slug === chapter.slug);
const previousChapter = chapterIndex > 0 ? chapters[chapterIndex - 1] : undefined;
const nextChapter = chapterIndex < chapters.length - 1 ? chapters[chapterIndex + 1] : undefined;
---

<BaseLayout title={`${chapterTitle} — ASM`} description={chapterDescription} canonicalPath={canonicalPath}>
  <div class="app-shell" style={`--chapter-accent:${chapterAccent}`}>
    <TopBar chapters={chapters} currentChapterNumber={chapterNumber} currentNav="chapters" />
    <div class="mobile-nav-overlay" data-nav-overlay></div>

    <aside class="sidenav" data-sidenav>
      <ChapterSidebar chapters={chapters} currentSlug={chapter.slug} />
    </aside>

    <section class="content-pane">
      <article class="doc-content chapter-page" data-doc-content>
        <header class="chapter-header">
          <p class="chapter-index">{chapterEyebrow(chapterNumber)}</p>
          <h1>{chapterLabel(chapter.data.title, chapterNumber)}</h1>
          <p class="chapter-meta">{chapter.data.summary}</p>
          <div class="chapter-divider"></div>
          <span class={`status ${chapter.data.status}`}>{statusLabels[chapter.data.status] || chapter.data.status}</span>
        </header>

        {isScaffolded && (
          <section class="panel scaffold-callout">
            <p class="callout-title">Coming Soon</p>
            <p>
              This chapter is in preparation. The final prose and supporting material will be published in a later update.
            </p>
            <p><a href="/chapter-1-foundations/">Read Chapter 1 (live)</a></p>
          </section>
        )}

        {!hasInlineFigurePlacement && chapterFigures.length > 0 && (
          <section class="chapter-figure-flow transitional-figure-flow">
            {chapterFigures.map((figure) => <FigureEmbed figure={figure} />)}
          </section>
        )}

        <section class="panel prose-block">
          <Content />
        </section>

        {(previousChapter || nextChapter) && (
          <nav class="chapter-pagination" aria-label="Chapter continuation">
            {previousChapter ? (
              <a class="chapter-pagination-link previous" href={`/${previousChapter.slug}/`}>
                <span class="card-num">Previous</span>
                <strong>{chapterNavLabel(previousChapter.data.title, previousChapter.data.chapter_number)}</strong>
              </a>
            ) : (
              <span></span>
            )}

            {nextChapter ? (
              <a class="chapter-pagination-link next" href={`/${nextChapter.slug}/`}>
                <span class="card-num">Next</span>
                <strong>{chapterNavLabel(nextChapter.data.title, nextChapter.data.chapter_number)}</strong>
              </a>
            ) : (
              <span></span>
            )}
          </nav>
        )}
      </article>
    </section>

    <aside class="outline-pane">
      <OutlineSidebar title="On this page" figureTitle="Figures in this chapter" figures={figureLinks} />
    </aside>
  </div>
</BaseLayout>
