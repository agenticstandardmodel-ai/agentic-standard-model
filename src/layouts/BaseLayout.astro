---
import '../styles/global.css';

type Props = {
  title?: string;
  description?: string;
  canonicalPath?: string;
};

const {
  title = 'The Agentic Standard Model',
  description = 'Interactive textbook for The Agentic Standard Model.',
  canonicalPath = '/'
} = Astro.props;

const canonicalUrl = new URL(canonicalPath, Astro.site);
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=DM+Mono:wght@400;500&family=IBM+Plex+Sans:wght@400;500;600&family=IBM+Plex+Serif:wght@400;600&display=swap"
      rel="stylesheet"
    />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl.href} />

    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl.href} />
    <meta property="og:site_name" content="The Agentic Standard Model" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />

    <script is:inline>
      (() => {
        try {
          const stored = localStorage.getItem('asm-theme');
          const systemPrefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
          const theme = stored || (systemPrefersDark ? 'dark' : 'light');
          document.documentElement.setAttribute('data-theme', theme);
        } catch {
          document.documentElement.setAttribute('data-theme', 'light');
        }
      })();
    </script>
  </head>
  <body>
    <slot />

    <script is:inline>
      (() => {
        const themeButton = document.querySelector('[data-theme-toggle]');
        const labelFor = (theme) => (theme === 'dark' ? 'Switch to light theme' : 'Switch to dark theme');

        if (themeButton) {
          const current = document.documentElement.getAttribute('data-theme') || 'light';
          themeButton.setAttribute('aria-label', labelFor(current));

          themeButton.addEventListener('click', () => {
            const now = document.documentElement.getAttribute('data-theme') || 'light';
            const next = now === 'dark' ? 'light' : 'dark';
            document.documentElement.setAttribute('data-theme', next);
            localStorage.setItem('asm-theme', next);
            themeButton.setAttribute('aria-label', labelFor(next));
          });
        }

        const appShell = document.querySelector('.app-shell');
        const navToggle = document.querySelector('[data-nav-toggle]');
        const navOverlay = document.querySelector('[data-nav-overlay]');

        const closeNav = () => {
          if (!appShell) return;
          appShell.classList.remove('nav-open');
        };

        if (navToggle && appShell) {
          navToggle.addEventListener('click', () => {
            appShell.classList.toggle('nav-open');
          });
        }

        if (navOverlay) {
          navOverlay.addEventListener('click', closeNav);
        }

        const contentRoot = document.querySelector('[data-doc-content]');
        const outlineList = document.querySelector('[data-outline-list]');
        const activeSectionList = document.querySelector('[data-active-section-list]');
        const figureLists = [...document.querySelectorAll('[data-figure-list]')];

        if (!contentRoot || (!outlineList && !activeSectionList && figureLists.length === 0)) return;

        const headingNodes = [
          ...contentRoot.querySelectorAll('h2, h3')
        ].filter((heading) => heading.textContent && heading.textContent.trim().length > 0);

        const slugify = (value) =>
          value
            .toLowerCase()
            .trim()
            .replace(/[^a-z0-9\s-]/g, '')
            .replace(/\s+/g, '-')
            .replace(/-+/g, '-');

        const used = new Set();
        if (headingNodes.length) {
          headingNodes.forEach((heading) => {
            if (!heading.id) {
              const base = slugify(heading.textContent || 'section');
              let candidate = base || 'section';
              let count = 2;
              while (used.has(candidate) || document.getElementById(candidate)) {
                candidate = `${base}-${count}`;
                count += 1;
              }
              heading.id = candidate;
            }
            used.add(heading.id);
          });
        }

        const createItem = (heading) => {
          const li = document.createElement('li');
          li.className = heading.tagName.toLowerCase() === 'h3' ? 'level-3' : 'level-2';

          const link = document.createElement('a');
          link.href = `#${heading.id}`;
          link.textContent = heading.textContent?.trim() || '';
          li.appendChild(link);

          return li;
        };

        const populate = (container) => {
          if (!container) return;
          container.innerHTML = '';
          headingNodes.forEach((heading) => container.appendChild(createItem(heading)));
        };

        if (headingNodes.length) {
          populate(outlineList);
          populate(activeSectionList);
        }

        const allLinks = [
          ...(outlineList ? [...outlineList.querySelectorAll('a')] : []),
          ...(activeSectionList ? [...activeSectionList.querySelectorAll('a')] : []),
          ...figureLists.flatMap((list) => [...list.querySelectorAll('a')])
        ];

        const trackedIds = [...new Set(
          allLinks
            .map((link) => link.getAttribute('href') || '')
            .filter((href) => href.startsWith('#'))
            .map((href) => href.replace('#', ''))
        )];

        if (!allLinks.length || !trackedIds.length) return;

        const setActive = (id) => {
          allLinks.forEach((link) => {
            link.classList.toggle('active', link.getAttribute('href') === `#${id}`);
          });
        };

        const observer = new IntersectionObserver(
          (entries) => {
            const visible = entries
              .filter((entry) => entry.isIntersecting)
              .sort((a, b) => a.boundingClientRect.top - b.boundingClientRect.top);

            if (visible.length > 0) {
              setActive(visible[0].target.id);
            }
          },
          {
            root: null,
            rootMargin: '-96px 0px -70% 0px',
            threshold: [0, 1]
          }
        );

        trackedIds.forEach((id) => {
          const target = document.getElementById(id);
          if (target) observer.observe(target);
        });

        window.addEventListener('hashchange', () => {
          const hash = window.location.hash.replace('#', '');
          if (hash) setActive(hash);
        });

        const initial = window.location.hash.replace('#', '') || trackedIds[0];
        if (initial) setActive(initial);
      })();
    </script>
  </body>
</html>
